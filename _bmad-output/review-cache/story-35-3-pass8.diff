+      email: 'electric@example.com',
+    });
+
+    const user = userEvent.setup();
+    render(<ElectricSubscribeForm />);
+
+    const emailInput = screen.getByLabelText(/email/i);
+    await user.type(emailInput, 'electric@example.com');
